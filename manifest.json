{
   "action": {
      "default_icon": {
         "128": "icon128.png",
         "16": "icon16.png",
         "48": "icon48.png"
      },
      "default_popup": "popup.html"
   },
   "content_scripts": [
      {
         "all_frames": true,
         "js": [
            "content.js"
         ],
         "matches": [
            "<all_urls>"
         ],
         "run_at": "document_start"
      }
   ],
   "description": "Stop websites from opening unwanted new tabs. Includes iframe and shadow-dom protection.",
   "host_permissions": [
      "<all_urls>"
   ],
   "manifest_version": 3,
   "name": "NoMoreTabs",
   "permissions": [
      "scripting",
      "storage",
      "activeTab"
   ],
   "version": "1.0",
   "web_accessible_resources": [
      {
         "matches": [
            "<all_urls>"
         ],
         "resources": [
            "inject.js",
            "allowlist.json"
         ]
      }
   ]
}